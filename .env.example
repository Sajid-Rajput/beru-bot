# ══════════════════════════════════════════════════
#  Beru Bot — Environment Configuration
#  Copy this file to .env and fill in your values.
#  .env is GITIGNORED — never commit secrets.
# ══════════════════════════════════════════════════

# ── Bot ────────────────────────────────────────────
BOT_TOKEN=                              # Telegram bot token from @BotFather
BOT_MODE=webhook                        # webhook | polling (use polling for local dev)
BOT_WEBHOOK=                            # Full URL: https://<DOMAIN>/telegram (webhook mode only)
BOT_WEBHOOK_SECRET=                     # Random secret ≥12 chars (Telegram webhook verification)
BOT_ADMINS=[]                           # JSON array of admin Telegram IDs  e.g. [123456789]
BOT_ALLOWED_UPDATES=[]                  # JSON array of update types (empty = all)
DOMAIN=                                 # e.g. bot.berubot.com (production domain)
BOT_USERNAME=BeruMonarchBot
SUPPORT_BOT=BeruSupportBot

# ── Database ───────────────────────────────────────
DB_USER=beru
DB_PASSWORD=                            # Strong random password
DB_NAME=beru_bot
DB_HOST=postgres                        # Docker service name (use localhost for local dev)
DB_PORT=5432
DATABASE_URL=postgresql://beru:CHANGE_ME@postgres:5432/beru_bot

# ── Redis ──────────────────────────────────────────
REDIS_HOST=redis                        # Docker service name (use localhost for local dev)
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Security ───────────────────────────────────────
MASTER_KEY_SECRET=                      # 64 hex chars (32 bytes). BACK THIS UP SECURELY.
                                        # Generate: openssl rand -hex 32
QN_WEBHOOK_SECRET=                      # QuickNode Stream webhook HMAC signing secret

# ── Solana ─────────────────────────────────────────
SOLANA_RPC_URL=                         # QuickNode RPC endpoint (https://...)
PLATFORM_FEE_WALLET=                    # Solana wallet address for collecting platform fees
PLATFORM_FEE_PERCENTAGE=0.01            # Platform fee as decimal (0.01 = 1%)

# ── QuickNode ──────────────────────────────────────
QN_STREAM_ID=                           # QuickNode Stream ID
QN_API_KEY=                             # QuickNode API key (for KV store + Streams API)
QN_KV_STORE_ID=                         # QuickNode KV store ID

# ── Referral ───────────────────────────────────────
REFERRAL_TIER1_PCT=0.35                 # 35% of fee to direct referrer
REFERRAL_TIER2_PCT=0.05                 # 5% of fee to sub-referrer
REFERRAL_USER_DISCOUNT_PCT=0.10         # 10% fee discount for referred users
REFERRAL_MIN_PAYOUT_SOL=0.01            # Minimum payout in SOL
REFERRAL_LINK_FORMAT=https://t.me/BeruMonarchBot?start=ref_{telegramId}

# ── Logging / Debug ────────────────────────────────
LOG_LEVEL=info                          # trace | debug | info | warn | error | fatal | silent
DEBUG=false                             # Set true for verbose debug output (dev only)
SERVER_HOST=0.0.0.0
SERVER_PORT=3000