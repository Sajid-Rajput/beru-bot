{
  "name": "beru-bot",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Beru Bot — Shadow Sell v2",
  "packageManager": "pnpm@10.24.0",
  "imports": {
    "#root/*": "./build/src/*"
  },
  "author": "Sajid-Rajput",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "tsc-watch --onSuccess \"tsx ./src/main.ts\"",
    "start": "tsc && tsx ./src/main.ts",
    "start:force": "tsx ./src/main.ts",
    "prepare": "husky || true",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@grammyjs/auto-chat-action": "0.1.1",
    "@grammyjs/commands": "1.0.5",
    "@grammyjs/conversations": "^2.1.1",
    "@grammyjs/hydrate": "1.4.1",
    "@grammyjs/i18n": "1.1.2",
    "@grammyjs/parse-mode": "1.11.1",
    "@grammyjs/runner": "2.0.3",
    "@grammyjs/types": "3.19.0",
    "@hono/node-server": "1.13.8",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "bullmq": "^5.70.1",
    "callback-data": "1.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "grammy": "1.35.0",
    "hono": "4.7.2",
    "ioredis": "^5.10.0",
    "iso-639-1": "3.1.5",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "postgres": "^3.4.8",
    "tsx": "4.19.3",
    "valibot": "0.42.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "4.3.0",
    "@types/node": "^22.13.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.20.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "tsc-watch": "^6.2.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": "eslint"
  }
}
